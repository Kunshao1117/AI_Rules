{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -ExecutionPolicy Bypass -Command '$raw=[Console]::In.ReadToEnd(); $payload=$null; try{$payload=ConvertFrom-Json -InputObject $raw -ErrorAction Stop}catch{}; $root=(git rev-parse --show-toplevel 2>$null); if(-not $root -and $payload){$root=$payload.cwd}; $script=Join-Path $root \".codex/hooks/team-native-gate.ps1\"; if(Test-Path -LiteralPath $script){$env:AI_RULES_HOOK_STDIN=$raw; & $script}else{ConvertTo-Json -InputObject @{systemMessage=\"Codex hook script was not found\";hookSpecificOutput=@{hookEventName=\"PreToolUse\";additionalContext=\"Codex hook script was not found; advisory/reminder only.\"}} -Depth 8 -Compress}'",
            "commandWindows": "pwsh -NoLogo -NoProfile -NonInteractive -ExecutionPolicy Bypass -EncodedCommand ",
            "timeout": 30,
            "statusMessage": "團隊啟動提醒"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
