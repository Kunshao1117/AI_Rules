{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -ExecutionPolicy Bypass -EncodedCommand ",
            "commandWindows": "powershell -NoProfile -ExecutionPolicy Bypass -EncodedCommand ",
            "statusMessage": "團隊啟動提醒",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -ExecutionPolicy Bypass -EncodedCommand ",
            "commandWindows": "powershell -NoProfile -ExecutionPolicy Bypass -EncodedCommand ",
            "statusMessage": "隊長越界提醒",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
