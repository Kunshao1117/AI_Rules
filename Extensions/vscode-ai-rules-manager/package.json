{
  "name": "ai-rules-manager",
  "displayName": "AI Rules Manager",
  "description": "Point-and-click VS Code manager for AI_Rules source updates, governance checks, rule sync, and orphan cleanup.",
  "icon": "resources/icon.png",
  "version": "0.1.16",
  "publisher": "kunshao",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kunshao1117/AI_Rules.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onView:aiRules.panel",
    "onCommand:aiRules.checkUpdate",
    "onCommand:aiRules.checkExtensionUpdate",
    "onCommand:aiRules.planUpdate",
    "onCommand:aiRules.applyUpdate",
    "onCommand:aiRules.doctor",
    "onCommand:aiRules.syncCoverageCheck",
    "onCommand:aiRules.syncGlobalRules",
    "onCommand:aiRules.syncProjectRules",
    "onCommand:aiRules.syncProjectRulesCodex",
    "onCommand:aiRules.syncProjectRulesClaude",
    "onCommand:aiRules.syncProjectRulesAntigravity",
    "onCommand:aiRules.gitignoreMaintenance",
    "onCommand:aiRules.memoryMigration",
    "onCommand:aiRules.cleanupOrphans"
  ],
  "contributes": {
    "configuration": {
      "title": "AI Rules",
      "properties": {
        "aiRules.repoRoot": {
          "type": "string",
          "scope": "application",
          "default": "",
          "description": "User setting only. Optional local AI_Rules repository root. When set, this path must contain Scripts/AI-RulesManager.ps1."
        },
        "aiRules.repoUrl": {
          "type": "string",
          "scope": "application",
          "default": "https://github.com/Kunshao1117/AI_Rules.git",
          "description": "User setting only. Git URL used to create the managed AI_Rules cache when the current workspace is not the AI_Rules repository."
        },
        "aiRules.powerShellPath": {
          "type": "string",
          "scope": "application",
          "default": "powershell.exe",
          "description": "User setting only. PowerShell executable used to run AI_Rules scripts."
        }
      }
    },
    "commands": [
      {
        "command": "aiRules.checkUpdate",
        "title": "AI Rules: 檢查來源狀態"
      },
      {
        "command": "aiRules.checkExtensionUpdate",
        "title": "AI Rules: 檢查 VSIX 安裝包新版"
      },
      {
        "command": "aiRules.planUpdate",
        "title": "AI Rules: 查看來源更新影響"
      },
      {
        "command": "aiRules.applyUpdate",
        "title": "AI Rules: 更新 AI_Rules 來源庫"
      },
      {
        "command": "aiRules.doctor",
        "title": "AI Rules: 治理巡檢 Doctor"
      },
      {
        "command": "aiRules.syncCoverageCheck",
        "title": "AI Rules: 同步完整性檢查"
      },
      {
        "command": "aiRules.syncGlobalRules",
        "title": "AI Rules: 同步使用者層規則"
      },
      {
        "command": "aiRules.syncProjectRules",
        "title": "AI Rules: 同步已安裝平台規則"
      },
      {
        "command": "aiRules.syncProjectRulesCodex",
        "title": "AI Rules: 同步 Codex 專案規則"
      },
      {
        "command": "aiRules.syncProjectRulesClaude",
        "title": "AI Rules: 同步 Claude 專案規則"
      },
      {
        "command": "aiRules.syncProjectRulesAntigravity",
        "title": "AI Rules: 同步 Antigravity 專案規則"
      },
      {
        "command": "aiRules.cleanupOrphans",
        "title": "AI Rules: 清理孤兒檔案"
      },
      {
        "command": "aiRules.memoryMigration",
        "title": "AI Rules: 記憶主檔遷移"
      },
      {
        "command": "aiRules.gitignoreMaintenance",
        "title": "AI Rules: 版控排除規則健檢"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aiRules",
          "title": "AI Rules",
          "icon": "resources/ai-rules.svg"
        }
      ]
    },
    "views": {
      "aiRules": [
        {
          "id": "aiRules.panel",
          "name": "AI Rules",
          "type": "webview"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^2.32.0",
    "typescript": "^5.5.4"
  }
}
